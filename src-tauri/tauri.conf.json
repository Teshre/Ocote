{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../frontend",
    "distDir": "../frontend",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Ocote",
    "version": "0.5.4"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "notification": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "mx.ocote.terminal",
      "resources": [
        "resources/shell/.zshenv",
        "resources/shell/.zshrc",
        "resources/shell/prompt.zsh",
        "resources/shell/bash-hook.bash",
        "resources/shell/prompt.fish",
        "resources/shell/prompt.ps1",
        "resources/zsh-syntax-highlighting/**/*",
        "resources/zsh-autosuggestions/zsh-autosuggestions.zsh",
        "resources/icons/icon-light.png",
        "resources/icons/icon-dark.png",
        "resources/icons/icon-light.icns",
        "resources/icons/icon-dark.icns"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "copyright": "© 2026 Ocote. MIT License.",
      "category": "DeveloperTool",
      "shortDescription": "Terminal offline, sin IA, hecha para humanos",
      "longDescription": "Ocote es una terminal de línea de comandos con explorador de archivos integrado, autocompletado contextual y tooltips educativos. 100% offline, sin IA, hecha para América Latina.",
      "macOS": {
        "frameworks": [],
        "exceptionDomain": null,
        "signingIdentity": null,
        "providerShortName": null,
        "entitlements": null,
        "minimumSystemVersion": "10.15"
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "es-MX"
        },
        "nsis": {
          "installMode": "currentUser",
          "languages": ["SimpChinese"],
          "displayLanguageSelector": false
        }
      },
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Ocote",
        "width": 1100,
        "height": 700,
        "minWidth": 700,
        "minHeight": 400
      }
    ]
  }
}
